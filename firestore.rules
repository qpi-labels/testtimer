rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: daily_records
    // Document ID: {date}_{uid}
    // Fields:
    //   - uid: string (required, immutable) - The user's ID
    //   - userName: string (required) - The user's display name
    //   - date: string (required, immutable) - The date in YYYY-MM-DD
    //   - totalMs: number (required) - Total study time in ms
    //   - updatedAt: timestamp (required) - Last updated time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDailyRecord(data) {
      return hasOnlyAllowedFields(['uid', 'userName', 'date', 'totalMs', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 50 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.totalMs is number && data.totalMs >= 0 &&
             data.updatedAt is timestamp;
    }

    match /daily_records/{recordId} {
      // Anyone authenticated can read the leaderboard
      allow read: if isAuthenticated();

      // Users can only create their own records
      allow create: if isAuthenticated() &&
                    isValidDailyRecord(request.resource.data) &&
                    request.resource.data.uid == request.auth.uid &&
                    recordId == request.resource.data.date + '_' + request.auth.uid;

      // Users can only update their own records
      allow update: if isAuthenticated() &&
                    isDocOwner() &&
                    isValidDailyRecord(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.date == resource.data.date;

      // Users can delete their own records
      allow delete: if isDocOwner();
    }
  }
}
